{
  "name": "remote-cli",
  "version": "0.1.0",
  "description": "Feishu Terminal Bot - Remote terminal control via Feishu chat",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "deadcode": "knip --no-config-hints",
    "clean": "rm -rf dist",
    "deploy": "npm run build && pm2 delete remote-cli --silent 2>/dev/null; pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop remote-cli",
    "pm2:restart": "pm2 restart remote-cli",
    "pm2:logs": "pm2 logs remote-cli",
    "pm2:status": "pm2 status"
  },
  "keywords": [
    "feishu",
    "lark",
    "terminal",
    "pty",
    "remote",
    "bot"
  ],
  "author": "songkang",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.98",
    "@larksuiteoapi/node-sdk": "^1.29.0",
    "@opencode-ai/sdk": "^1.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
"@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "knip": "^6.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
