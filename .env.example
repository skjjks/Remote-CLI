# Feishu Bot Configuration
FEISHU_APP_ID=your_app_id_here
FEISHU_APP_SECRET=your_app_secret_here

# Security — comma-separated Feishu user IDs
ALLOWED_USERS=user_id_1,user_id_2

# Server Configuration
PORT=3000
HOST=0.0.0.0

# Terminal Configuration
TERMINAL_COLS=80
TERMINAL_ROWS=24
SHELL=/bin/bash

# Session Configuration
SESSION_PREFIX=remote-cli
DATA_DIR=./data

# Claude Configuration
CLAUDE_TIMEOUT=300000
CLAUDE_DEFAULT_MODE=default
# CLAUDE_CARD_UPDATE_INTERVAL=500

# Timing (ms) — usually no need to change
# TIMING_SHELL_CAPTURE_DELAY=1500
# TIMING_RAW_CAPTURE_DELAY=400
# TIMING_CLAUDE_STARTUP_WAIT=3000
# TIMING_CLAUDE_POLL_INTERVAL=1000
# TIMING_CLAUDE_FIRST_POLL_DELAY=1500
# TIMING_CLAUDE_MENU_POLL_DELAY=1000
# TERMINAL_HISTORY_LIMIT=50000
